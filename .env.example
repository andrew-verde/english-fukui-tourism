# Google Places API
GOOGLE_API_KEY=your_google_api_key

# Optional non-Places Google Maps review collection.
# Use this to collect more than the Google Places 5-review slice.
OUTSCRAPER_API_KEY=your_outscraper_api_key
GOOGLE_MAPS_DEEP_REVIEW_LIMIT=100
# Use existing checkpoint place_ids first to avoid fuzzy Maps query mismatches.
GOOGLE_MAPS_DEEP_QUERY_MODE=place-id-or-search

# Data Collection Settings
# GOOGLE_MAPS_REVIEW_LIMIT: Maximum reviews per Google Place. API hard-caps at 5.
GOOGLE_MAPS_REVIEW_LIMIT=5
# REVIEW_DATE_CUTOFF: Drop reviews published before this date (YYYY-MM-DD).
# Set to 2024-06-01 to capture post-Hokuriku Shinkansen reviews only.
REVIEW_DATE_CUTOFF=2024-06-01

# Testing Configuration
# TESTING_MODE: When true, all scrapers use reduced limits for quick testing
TESTING_MODE=false

# Statistical validation
STATS_PERMUTATIONS=10000
STATS_PERMUTATION_SEED=42

# Mention splitting
MENTION_MIN_CHARS=4

# Cross-language trends side project (separate from thesis pipeline)
# TOURISM_DATA_DIR: checkout of the companion Chinese social-media scrape repo.
TOURISM_DATA_DIR=/home/andrewgreen/Repositories/external/tourism-data
# CN_SCRAPE_REFERENCE_DATE: override the scrape anchor date (YYYY-MM-DD) used to
# resolve year-inferred/relative Xiaohongshu post dates. Defaults to the raw
# file's git commit date (or mtime outside a checkout).
#CN_SCRAPE_REFERENCE_DATE=2026-06-12

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/analysis.log
ESTAT_APP_ID=your_estat_app_id
