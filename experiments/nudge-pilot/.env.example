# Copy these into Vercel Project Settings -> Environment Variables.
# Do not commit real keys.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional. Leave unset unless you rename the table in database/supabase-schema.sql.
SUPABASE_TABLE=nudge_pilot_responses

# Optional comma-separated list. Usually not needed because same-origin Vercel
# requests are allowed automatically.
ALLOWED_ORIGINS=https://your-vercel-project.vercel.app
