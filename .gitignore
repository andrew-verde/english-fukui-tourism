# Google review row-level CSVs and checkpoints are tracked (pseudonymized
# reviewer handles); stale ignore entries removed when they were committed.
output/friction_analysis/presentation_figures/
# Chinese social row-level data stays local: it carries real author handles
# and source URLs from the companion tourism-data scrape.
output/chinese_social_media_analysis/chinese_social_posts.csv
output/chinese_social_media_analysis/tagged_chinese_social_posts.csv
# Official survey datasets are LFS-tracked at the pinned vintage for thesis
# traceability (see docs/data_reproducibility.md). Only refetchable lookup
# CSVs from the fetch script stay ignored.
output/official_fukui/raw/*.csv
!output/official_fukui/raw/ishikawa_survey_*.csv
!output/official_fukui/raw/ftas_survey_all.csv
output/official_fukui/japanese_friction_validation_sample.csv
